# Telegram bot — create one with @BotFather, then paste the token here.
# In BotFather also run /setprivacy -> Enable so the bot only sees messages
# directed at it (commands and replies), not all group chatter.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token
# Override only if you run a self-hosted Telegram Bot API server.
TELEGRAM_API_BASE=https://api.telegram.org

# Runtime/agent settings use the CODEWHALE_* names. The legacy DEEPSEEK_*
# equivalents are still accepted as a fallback; if both are set, CODEWHALE_* wins.
CODEWHALE_RUNTIME_URL=http://127.0.0.1:7878
CODEWHALE_RUNTIME_TOKEN=replace-with-same-token-as-runtime-env
CODEWHALE_WORKSPACE=/opt/whalebro
CODEWHALE_MODEL=auto
CODEWHALE_MODE=agent
CODEWHALE_ALLOW_SHELL=true
CODEWHALE_TRUST_MODE=false
CODEWHALE_AUTO_APPROVE=false

# Allowlist of Telegram numeric chat ids (DMs) or user ids, comma-separated.
# Telegram bots are reachable by anyone who finds them, so this is the primary
# access control. Leave empty + CODEWHALE_ALLOW_UNLISTED=true ONLY for first
# pairing: message the bot, read the chat_id it prints back, paste it here,
# set CODEWHALE_ALLOW_UNLISTED=false, and restart.
CODEWHALE_CHAT_ALLOWLIST=
CODEWHALE_ALLOW_UNLISTED=false

TELEGRAM_THREAD_MAP_PATH=/var/lib/codewhale-telegram-bridge/thread-map.json
TELEGRAM_ALLOW_GROUPS=false
TELEGRAM_REQUIRE_PREFIX_IN_GROUP=true
TELEGRAM_GROUP_PREFIX=/ds
TELEGRAM_MAX_REPLY_CHARS=3900
TELEGRAM_POLL_TIMEOUT_SEC=50
CODEWHALE_TURN_TIMEOUT_MS=900000
